@model File
@{
    ViewData["Title"] = $"MyNotes - /{Model.Name}";
    List<Note> notes = ViewBag.Notes;
}

<nav>
    <ol class="breadcrumb">
        @if (Context.User.Identity.IsAuthenticated)
        {
            <li class="breadcrumb-item"><a asp-controller="Files" asp-action="Index">Files</a></li>
            @foreach (var ancestor in ViewBag.Ancestors)
            {
                <li class="breadcrumb-item"><a asp-action="View" asp-route-id="@ancestor.Id">@ancestor.Name</a></li>
            }
        }
        <li class="breadcrumb-item active">
            <span>@Model.Name</span>
            @if (Model.IsPublic)
            {
                <span class="badge text-success ms-2">Public</span>
            }
        </li>
    </ol>
</nav>

@if (Context.User.Identity.IsAuthenticated)
{
  <div class="btn-toolbar mb-3">
    <a asp-controller="Files" asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary me-3">
      <i class="bi bi-pencil-fill"></i>
    </a>
    <button id="batchToggle" type="button" class="btn btn-outline-primary me-3">
      <i class="bi bi-check2-square"></i>
    </button>
    <button id="uploadToggle" type="button" class="btn btn-outline-primary me-3">
      <i class="bi bi-upload"></i>
    </button>
    <a asp-controller="Notes" asp-action="Create" asp-route-parentId="@Model.Id" class="btn btn-outline-primary me-3">
      <i class="bi bi-clipboard-plus"></i>
    </a>
    <button id="newFolderToggle" type="button" class="btn btn-outline-primary">
      <i class="bi bi-folder-plus"></i>
    </button>
    <div id="newFolderForm" class="input-group ms-2">
      <input id="newFolder" type="text" class="form-control" style="width: 20em;">
      <div class="input-group-text" id="clearBtn"><i class="bi bi-x-lg"></i></div>
    </div>
  </div>

    <form id="uploadForm" asp-controller="Files" asp-action="Upload" class="dropzone"
          method="post" enctype="multipart/form-data">
        <input type="hidden" name="parentId" value="@Model.Id" />
    </form>

  <div id="batchActionBar" class="alert alert-info py-2 mb-3 d-none align-items-center">
    <span id="batchSummary" class="me-auto">0 selected</span>
    <button id="batchMove" type="button" class="btn btn-outline-primary btn-sm me-2" disabled>
      <i class="bi bi-folder-symlink-fill me-1"></i>Move
    </button>
    <button id="batchDelete" type="button" class="btn btn-outline-danger btn-sm me-2" disabled>
      <i class="bi bi-trash-fill me-1"></i>Delete
    </button>
    <button id="batchCancel" type="button" class="btn btn-outline-secondary btn-sm">
      <i class="bi bi-x-lg me-1"></i>Cancel
    </button>
  </div>
}

<table id="folderItems" class="table table-hover table-striped align-middle">
    <thead>
        <tr>
          <th class="batch-column">
            <input id="selectAll" class="form-check-input" type="checkbox"/>
          </th>
            <th>Name</th>
            <th class="d-none d-lg-table-cell">Size</th>
            <th class="d-none d-lg-table-cell">Updated</th>
          <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var note in notes)
        {
            <tr>
              <td class="batch-column">
                <input class="batch-select form-check-input" type="checkbox"
                       data-type="note" data-id="@note.Id" data-name="@note.Subject"/>
              </td>
                <td>
                    <i class="note @(note.IsPublic ? "bi-file-text" : "bi-file-text-fill") me-2" style="color: orange;" data-note-id="@note.Id"></i>
                    <a asp-controller="Notes" asp-action="View" asp-route-id="@note.Id">@note.Subject</a>
                </td>
                <td class="d-none d-lg-table-cell"></td>
                <td class="d-none d-lg-table-cell">@note.Updated.ToLocalTime().ToString("d")</td>
                <td class="text-nowrap">
                    @if (Context.User.Identity.IsAuthenticated)
                    {
                        <a asp-controller="Notes" asp-action="Edit" asp-route-id="@note.Id"
                           class="btn btn-outline-primary btn-sm me-2 d-none d-md-inline">
                            <i class="bi bi-pencil-fill"></i>
                        </a>
                    }
                </td>
            </tr>
        }
        @foreach (var file in Model.Children)
        {
            string icon;
            if (file.IsFolder)
                icon = file.IsPublic ? "bi-folder" : "bi-folder-fill";
            else
                icon = file.IsPublic ? "bi-file-earmark" : "bi-file-earmark-fill";
            var batchType = file.IsFolder ? "folder" : "file";
            <tr>
              <td class="batch-column">
                <input class="batch-select form-check-input" type="checkbox"
                       data-type="@batchType" data-id="@file.Id" data-name="@file.Name"/>
              </td>
                @if (file.IsFolder)
                {

                    <td>
                        <i class="folder @icon me-2" style="color: orange;" data-file-id="@file.Id"></i>
                        <a asp-action="View" asp-route-id="@file.Id">@file.Name</a>
                    </td>
                    <td class="d-none d-lg-table-cell"></td>
                }
                else
                {
                    <td>
                        <i class="file @icon me-2" style="color: orange;" data-file-id="@file.Id"></i>
                        <a asp-controller="Files" asp-action="View" asp-route-id="@file.Id">@file.Name</a>
                        @if (file.Version > 1)
                        {
                            <span class="badge text-light">v@(file.Version)</span>
                        }
                    </td>
                    <td class="d-none d-lg-table-cell text-nowrap">@file.GetFormattedSize()</td>
                }
                <td class="d-none d-lg-table-cell">@file.Updated.ToLocalTime().ToString("d")</td>
                <td class="text-nowrap">
                    @if (Context.User.Identity.IsAuthenticated)
                    {
                        <a asp-controller="Files" asp-action="Edit" asp-route-id="@file.Id"
                           class="btn btn-outline-primary btn-sm me-2 d-none d-md-inline">
                            <i class="bi bi-pencil-fill"></i>
                        </a>
                    }
                    @if (!file.IsFolder)
                    {
                        <a asp-controller="Files" asp-action="Download" asp-route-id="@file.Id"
                           class="btn btn-outline-primary btn-sm">
                            <i class="bi bi-download"></i>
                        </a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

@if (Context.User.Identity.IsAuthenticated)
{
  <div id="batchMoveModal" class="modal" tabindex="-1">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">Move <span id="batchMoveSummary"></span> to <span id="currentFolder"></span></h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <div id="folders" data-id="" class="list-group list-group-flush">
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button id="doBatchMove" type="button" class="btn btn-primary">Move</button>
        </div>
      </div>
    </div>
  </div>

  <div id="batchDeleteModal" class="modal" tabindex="-1">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">Delete selected items?</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <p id="batchDeleteSummary" class="mb-0"></p>
          <p id="batchDeleteFolderWarning" class="text-danger mt-2 mb-0 d-none">
            Selected folders and their files/subfolders will be deleted.
          </p>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button id="doBatchDelete" type="button" class="btn btn-danger">Delete</button>
        </div>
      </div>
    </div>
  </div>
}

@section StyleSheets {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/dropzone/5.9.3/dropzone.min.css"
          integrity="sha512-jU/7UFiaW5UBGODEopEqnbIAHOI8fO6T99m7Tsmqs2gkdujByJfkCbbfPSN4Wlqlb9TGnsuC0YgUgWkRBK7B9A=="
          crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link href="https://cdn.datatables.net/v/bs5/dt-2.0.8/datatables.min.css" rel="stylesheet">
}
@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/dropzone/5.9.3/min/dropzone.min.js"
            integrity="sha512-oQq8uth41D+gIH/NJvSJvVB85MFk1eWpMK6glnkg6I7EdMqC1XVkW7RxLheXwmFdG03qScCM7gKS/Cx3FYt7Tg=="
            crossorigin="anonymous" referrerpolicy="no-referrer"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/luxon/3.4.4/luxon.min.js"></script>
    <script src="https://cdn.datatables.net/v/bs5/dt-2.0.8/datatables.min.js"></script>
    <script>
        Dropzone.options.uploadForm = {
            uploadMultiple: true,
            // uploadMultiple is true, Dropzone add [] to paramName. For some reason ASP.NET Core does not
            // bind it to a collection like for other parameter types. The paramName functio trick is from
            // https://stackoverflow.com/questions/58815724/how-to-integrate-dropzone-js-with-asp-net-core-mvc
            paramName: () => "uploadedFiles",
            parallelUploads: 10,
            timeout: 180000, // default timeout is 30s (30000ms) which is not enough for uploading large files
            queuecomplete: function () {
                location.reload();
            }
        };
        $(function () {
            $("#uploadForm").hide();
            $("#newFolderForm").hide();
            $("#uploadToggle").click(function () {
                $("#uploadForm").toggle();
            });
            $("#newFolderToggle").click(function () {
                $("#newFolderForm").toggle();
                if ($("#newFolderForm").is(":visible"))
                    $("#newFolder").focus();
            });
            $("#newFolder").keyup(function (event) {
                var keycode = (event.keyCode ? event.keyCode : event.which);
                var name = $(this).val();
                if (keycode == "13" && name) {
                    $.ajax({
                        url: "@Context.Request.PathBase/folders",
                        method: "post",
                        data: {
                            name,
                            parentId: @Model.Id
                                                                                                                                        },
                        success: function () {
                            location.reload();
                        }
                    });
                }
            });
            $("#clearBtn").click(function () {
                $("#newFolder").val("");
            });
            var fileIcons = ["bi-folder-fill", "bi-folder", "bi-file-earmark-fill", "bi-file-earmark"];
            var toggleIcons = function (element, icon1, icon2) {
                if (element.hasClass(icon1)) {
                    element.removeClass(icon1);
                    element.addClass(icon2);
                }
                else if (element.hasClass(icon2)) {
                    element.removeClass(icon2);
                    element.addClass(icon1);
                }
            }
            $(".file,.folder").click(function () {
                var fileId = $(this).attr("data-file-id");
                var value = $(this).hasClass(fileIcons[0]) || $(this).hasClass(fileIcons[2]) ? "True" : "False";
                $.ajax({
                    url: `@Context.Request.PathBase/files/${fileId}/IsPublic`,
                    method: "put",
                    data: { value },
                    context: $(this),
                    success: function () {
                        toggleIcons(this, fileIcons[0], fileIcons[1]);
                        toggleIcons(this, fileIcons[2], fileIcons[3]);
                    }
                });
            });
          var batchMode = false;
          var paths = [];
          var children;

          var getSelectedItems = function () {
            return $(".batch-select:checked").map(function () {
              return {
                type: String($(this).data("type")),
                id: Number($(this).data("id")),
                name: String($(this).data("name"))
              };
            }).get();
          };
          var getPayloadItems = function () {
            return getSelectedItems().map(item => ({
              type: item.type,
              id: item.id
            }));
          };
          var pluralize = function (count, singular, plural) {
            return `${count} ${count == 1 ? singular : plural}`;
          };
          var getTypeSummary = function (items) {
            var counts = {
              note: items.filter(item => item.type == "note").length,
              file: items.filter(item => item.type == "file").length,
              folder: items.filter(item => item.type == "folder").length
            };
            var parts = [];
            if (counts.note > 0) parts.push(pluralize(counts.note, "note", "notes"));
            if (counts.file > 0) parts.push(pluralize(counts.file, "file", "files"));
            if (counts.folder > 0) parts.push(pluralize(counts.folder, "folder", "folders"));
            return parts.join(", ");
          };
          var updateBatchControls = function () {
            var items = getSelectedItems();
            var selectedCount = items.length;
            var allCount = $(".batch-select").length;
            $("#batchSummary").text(selectedCount == 0
              ? "0 selected"
              : `${pluralize(selectedCount, "item", "items")} selected (${getTypeSummary(items)})`);
            $("#batchMove,#batchDelete").prop("disabled", selectedCount == 0);
            $("#selectAll")
              .prop("checked", allCount > 0 && selectedCount == allCount)
              .prop("indeterminate", selectedCount > 0 && selectedCount < allCount);
          };
          var setBatchMode = function (enabled) {
            batchMode = enabled;
            table.column(0).visible(batchMode);
            $("#batchActionBar")
              .toggleClass("d-none", !batchMode)
              .toggleClass("d-flex", batchMode);
            if (!batchMode)
              $(".batch-select,#selectAll").prop("checked", false);
            updateBatchControls();
          };
          var getSelectedFolderIds = function () {
            return getSelectedItems()
              .filter(item => item.type == "folder")
              .map(item => item.id);
          };
          var getChildFolders = function () {
                $.ajax({
                  url: "@Context.Request.PathBase/Folders/GetChildFolders",
                  data: paths[0].id ? {parentId: paths[0].id} : {},
                  success: function (results) {
                    $("#currentFolder").text(paths[0].name);
                    var selectedFolderIds = getSelectedFolderIds();
                    children = results.filter(r => !selectedFolderIds.includes(r.id));
                    if (paths.length > 1)
                      children.unshift({
                        id: paths[1].id,
                        name: ".."
                      });
                    var items = children.map(child => {
                      var item = $(`<button type="button" class="child list-group-item list-group-item-action" data-id="${child.id ?? ""}"></button>`);
                      item.text(child.name);
                      item.click(function () {
                        $(".child").removeClass("active");
                        $(this).addClass("active");
                      });
                      item.dblclick(function () {
                        if ($(this).text() == "..")
                          paths.shift();
                        else
                          paths.unshift(children.find(c => c.id == $(this).attr("data-id")));
                        getChildFolders();
                      });
                      return item;
                    });
                    $("#folders").empty().append(items);
                  }
                });
          };

          DataTable.datetime("M/d/yyyy");
          let table = new DataTable("#folderItems", {
                paging: false,
                searching: false,
                info: false,
                order: [],
                columnDefs: [
                  {targets: 0, orderable: false, visible: false},
                  {targets: [2, 4], orderable: false}
                ]
          });
          $("#batchToggle").click(function () {
            setBatchMode(!batchMode);
          });
          $("#batchCancel").click(function () {
            setBatchMode(false);
          });
          $("#folderItems").on("change", "#selectAll", function () {
            $(".batch-select").prop("checked", $(this).prop("checked"));
            updateBatchControls();
          });
          $("#folderItems").on("change", ".batch-select", updateBatchControls);
          $("#batchMove").click(function () {
            var items = getSelectedItems();
            if (items.length == 0) return;
            $("#batchMoveSummary").text(getTypeSummary(items));
            bootstrap.Modal.getOrCreateInstance(document.getElementById("batchMoveModal")).show();
          });
          $("#batchMoveModal").on("show.bs.modal", function () {
            paths = [{
              id: null,
              name: "/"
            }];
            getChildFolders();
          });
          $("#batchMoveModal").on("hide.bs.modal", function () {
            paths = [];
            $("#folders").empty();
          });
          $("#doBatchMove").click(function () {
            var selected = $("button.child.active");
            var parentId = selected.length == 1 ? selected.attr("data-id") : paths[0].id;
            var payload = {
              parentId: parentId ? Number(parentId) : null,
              items: getPayloadItems()
            };
            $.ajax({
              url: "@Context.Request.PathBase/Folders/BatchMove",
              method: "post",
              contentType: "application/json",
              data: JSON.stringify(payload),
              success: function () {
                location.reload();
              },
              error: function () {
                alert("Unable to move selected items.");
              }
            });
          });
          $("#batchDelete").click(function () {
            var items = getSelectedItems();
            if (items.length == 0) return;
            $("#batchDeleteSummary").text(`This will delete ${getTypeSummary(items)}.`);
            $("#batchDeleteFolderWarning").toggleClass("d-none", !items.some(item => item.type == "folder"));
            bootstrap.Modal.getOrCreateInstance(document.getElementById("batchDeleteModal")).show();
          });
          $("#doBatchDelete").click(function () {
            $.ajax({
              url: "@Context.Request.PathBase/Folders/BatchDelete",
              method: "post",
              contentType: "application/json",
              data: JSON.stringify({items: getPayloadItems()}),
              success: function () {
                location.reload();
              },
              error: function () {
                alert("Unable to delete selected items.");
              }
            });
            });
        });
    </script>
}
